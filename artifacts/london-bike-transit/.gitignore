# Build output
dist/

# iOS / Capacitor — generated by `npx cap add ios` and Xcode builds.
# The Xcode project itself (ios/App/App.xcodeproj) IS committed; only
# build artifacts and per-user state are ignored. Capacitor 8 uses
# Swift Package Manager, so there are no Pods to ignore.
ios/App/App/public/
ios/DerivedData/
ios/App/output/
ios/App/build/
*.xcuserstate
xcuserdata/
